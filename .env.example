API_PORT=3001
API_HOST=127.0.0.1
WEB_ORIGIN=http://127.0.0.1:5173
ENABLE_BOOT_SCAN=false

# Session/auth
SESSION_SECRET=change-me

# Nextcloud OAuth (required for login)
NEXTCLOUD_BASE_URL=https://cloud.example.com
NEXTCLOUD_APP_ID=replace-with-nextcloud-oauth-client-id
NEXTCLOUD_APP_SECRET=replace-with-nextcloud-oauth-client-secret
NEXTCLOUD_REDIRECT_URI=http://127.0.0.1:3001/api/auth/callback
