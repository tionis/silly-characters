# Server bind
SILLYCHARACTERS_HOST=127.0.0.1
SILLYCHARACTERS_PORT=48912

# Browser origin for auth callback redirects
WEB_ORIGIN=http://127.0.0.1:48912

# Session/auth
SESSION_SECRET=change-me

# Nextcloud OAuth (required)
NEXTCLOUD_BASE_URL=https://cloud.example.com
NEXTCLOUD_APP_ID=replace-with-nextcloud-oauth-client-id
NEXTCLOUD_APP_SECRET=replace-with-nextcloud-oauth-client-secret
NEXTCLOUD_REDIRECT_URI=http://127.0.0.1:48912/api/auth/callback

# Optional
# CORS_ALLOW_ORIGINS=http://127.0.0.1:48912
# ST_PORT=8000
# ENABLE_BOOT_SCAN=false
# CACHE_GC_INTERVAL_MS=900000
# CACHE_GC_MIN_AGE_MS=3600000
# CACHE_GC_INITIAL_DELAY_MS=30000
